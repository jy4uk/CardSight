# Frontend Environment Variables
# Copy this file to .env.local for local development

# API URL - set this to your Railway backend URL in production
# Leave empty for local development (uses proxy)
VITE_API_URL=

# Example production value:
# VITE_API_URL=https://your-app.railway.app/api

# CardLadder Firebase API key — same value as CARDLADDER_FIREBASE_API_KEY on the backend.
# Required for the "Sign in with Google" button in Account Settings → Integrations.
VITE_CARDLADDER_FIREBASE_API_KEY=
