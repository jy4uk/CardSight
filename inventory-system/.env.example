# Database Configuration
# Railway provides this automatically when you add PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Stripe Configuration (if using)
STRIPE_SECRET_KEY=your_stripe_secret_key

# PSA API Configuration
# Get your token from https://www.psacard.com/publicapi
PSA_API_TOKEN=your_psa_api_token

# eBay API Configuration (for PSA market data)
# Get credentials from https://developer.ebay.com/
EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret

# Authentication Configuration
# Generate secure random strings for production
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this

# Legacy Admin Mode Password
ADMIN_PASSWORD=cardsight2024

# CardLadder Integration (one-time setup — tokens auto-refresh forever)
#
# Step 1 — Get the Firebase API key:
#   Open app.cardladder.com → DevTools → Application → Local Storage
#   Find the key starting with "firebase:authUser:" — the suffix is the API key
#   e.g. key name = "firebase:authUser:AIzaSyXXX..." → API key = "AIzaSyXXX..."
#
# Step 2 — Get the refresh token:
#   Click that localStorage key → in the JSON value, find stsTokenManager.refreshToken
#
# That's it. The backend auto-refreshes the ID token before it expires.
CARDLADDER_FIREBASE_API_KEY=AIzaSy...
CARDLADDER_REFRESH_TOKEN=your_firebase_refresh_token
